# ── Security (MUST change before going live) ──────────────────────────────────
SECRET_KEY=replace-this-with-a-very-long-random-string-64-chars
ADMIN_SECRET=choose-a-strong-admin-password

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./chess.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# ── UPI Payment (set YOUR details here) ───────────────────────────────────────
UPI_ID=yourname@okaxis          # Your Google Pay / PhonePe / Paytm UPI ID
UPI_NAME=ChessWager             # Displayed on payer's screen
UPI_NOTE=ChessWager Deposit

# ── Business model ────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10         # 10% of prize pool goes to platform on every game
PAYOUT_HOLD_HOURS=24            # Hours to hold winnings before releasing
MIN_BET=10                      # Minimum bet ₹10
MAX_BET=100                     # Maximum bet ₹100
MAX_WALLET_BALANCE=100          # Max wallet balance ₹100

# ── Anti-cheat ────────────────────────────────────────────────────────────────
MIN_MOVE_TIME_MS=500
ACCESS_TOKEN_EXPIRE_MINUTES=60
