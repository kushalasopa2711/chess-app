# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" on the live server. Enables strict secret validation and
# tighter logging. Leave blank or set to "development" for local dev.
ENV=development

# ── Security (MUST change before going live) ──────────────────────────────────
# In production this MUST be set to a value of at least 32 characters,
# otherwise the app refuses to start.
SECRET_KEY=replace-this-with-a-very-long-random-string-64-chars
# Admin dashboard secret. In production must be ≥16 chars and not the default.
ADMIN_SECRET=choose-a-strong-admin-password

# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite is fine for development:
DATABASE_URL=sqlite+aiosqlite:///./chess.db
# Production — use managed Postgres. Either of these formats works; the app
# normalises postgres:// and postgresql:// into postgresql+asyncpg:// for you.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# Force SSL even when the host isn't a known managed provider:
# DATABASE_SSL=require

# ── CORS / origins ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API. Defaults to "*" which is
# fine for the bundled frontend served from the same domain.
# Example:  ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=*

# ── UPI Payment (set YOUR details here) ───────────────────────────────────────
UPI_ID=yourname@okaxis          # Your Google Pay / PhonePe / Paytm UPI ID
UPI_NAME=ChessWager             # Displayed on payer's screen
UPI_NOTE=ChessWager Deposit

# ── Business model ────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10         # 10% of prize pool goes to platform on every game
PAYOUT_HOLD_HOURS=24            # Hours to hold winnings before releasing
MIN_BET=10                      # Minimum bet ₹10
MAX_BET=100                     # Maximum bet ₹100
MAX_WALLET_BALANCE=100          # Max wallet balance ₹100

# ── Anti-cheat ────────────────────────────────────────────────────────────────
MIN_MOVE_TIME_MS=500
# Auto-ban after this many *server-rejected* illegal UCI attempts in a single game (default 12).
# Lower only if you want stricter enforcement; raising reduces false bans on laggy networks.
# MAX_ILLEGAL_MOVE_ATTEMPTS_PER_GAME=12
# Same illegal UCI string within this many seconds only counts once toward auto-ban (retries).
# ILLEGAL_MOVE_DEDUPE_WINDOW_SEC=4.0
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CPU built-in engine (speed vs strength) ───────────────────────────────────
# CPU_MOVE_DELAY_SEC=0.05
# CPU_AI_MAIN_DEPTH=3
# CPU_AI_QUIESCENCE_CAP=4
